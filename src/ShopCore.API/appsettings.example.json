{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ShopCoreDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Secret": "CHANGE-THIS-min-32-chars-use-a-strong-random-secret",
    "Issuer": "ShopCore",
    "Audience": "ShopCore",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Notify": {
    "Email": {
      "Provider": "smtp",
      "Smtp": {
        "Host": "sandbox.smtp.mailtrap.io",
        "Port": 2525,
        "Username": "YOUR-MAILTRAP-USERNAME",
        "Password": "YOUR-MAILTRAP-PASSWORD",
        "FromEmail": "from@example.com",
        "FromName": "ShopCore",
        "UseSsl": true
      }
    },
    "inapp": {
      "Enabled": true
    }
  },
  "PaymentGateways": {
    "DefaultGateway": "Razorpay",
    "EnabledGateways": [
      "Razorpay"
    ],
    "EnableCOD": true,
    "Razorpay": {
      "KeyId": "rzp_test_YOUR_KEY_ID",
      "KeySecret": "YOUR_RAZORPAY_SECRET",
      "WebhookSecret": "YOUR_RAZORPAY_WEBHOOK_SECRET"
    },
    "Stripe": {
      "PublishableKey": "pk_test_YOUR_PUBLISHABLE_KEY",
      "SecretKey": "sk_test_YOUR_SECRET_KEY",
      "WebhookSecret": "whsec_YOUR_WEBHOOK_SECRET"
    },
    "PayPal": {
      "ClientId": "YOUR_PAYPAL_CLIENT_ID",
      "ClientSecret": "YOUR_PAYPAL_CLIENT_SECRET",
      "UseSandbox": true,
      "WebhookId": "YOUR_PAYPAL_WEBHOOK_ID"
    }
  },
  "FileStorage": {
    "UploadPath": "wwwroot/uploads",
    "MaxFileSizeMB": 5,
    "AllowedExtensions": ".jpg,.jpeg,.png,.gif,.pdf"
  },
  "TaxSettings": {
    "GSTRate": 0.18,
    "RoundToDecimalPlaces": 2
  },
  "GoogleMapsSettings": {
    "ApiKey": "YOUR_GOOGLE_MAPS_API_KEY",
    "BaseUrl": "https://maps.googleapis.com/maps/api"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": {
    "PasswordReset": "https://yourapp.com/reset-password"
  }
}
